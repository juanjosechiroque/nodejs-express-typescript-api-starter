{
    "name": "nodejs-express-api-boilerplate",
    "version": "1.0.0",
    "description": "TypeScript REST API starter with Express 5, MongoDB, JWT, Docker, CI/CD, and tests",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "start": "NODE_ENV=production node dist/index.js",
        "dev": "NODE_ENV=development nodemon index.ts",
        "build": "tsc",
        "validate": "eslint . && prettier --check .",
        "format": "prettier --write . && eslint . --fix",
        "prepare": "husky || true",
        "test": "NODE_OPTIONS=--experimental-vm-modules jest",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "express",
        "nodejs",
        "rest-api",
        "boilerplate",
        "mongodb",
        "jwt",
        "mongoose"
    ],
    "author": "juanjosechiroque",
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.5",
        "express": "^5.0.1",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.0.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.9.4",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.1.0",
        "@types/supertest": "^7.2.0",
        "dotenv": "^16.4.7",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.0.0",
        "nodemon": "^3.1.9",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.1",
        "supertest": "^7.0.0",
        "ts-jest": "^29.4.11",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1"
    },
    "allowScripts": {
        "bcrypt@6.0.0": true,
        "esbuild@0.28.1": true,
        "fsevents@2.3.3": true,
        "unrs-resolver@1.11.1": true
    }
}
