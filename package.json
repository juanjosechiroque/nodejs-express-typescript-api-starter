{
    "name": "nodejs-express-api-boilerplate",
    "version": "1.0.0",
    "description": "REST API boilerplate with Express 5, MongoDB, JWT, and tests",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "node index.js",
        "dev": "NODE_ENV=development nodemon index.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --check .",
        "prettier:fix": "prettier --write .",
        "validate": "npm run lint && npm run prettier && npm test",
        "format": "npm run lint:fix && npm run prettier:fix",
        "prepare": "husky",
        "test": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --coverage"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "express": "^5.0.1",
        "helmet": "^8.0.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.9.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "dotenv": "^16.4.7",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.1.5",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "jest": "^30.0.0",
        "nodemon": "^3.1.9",
        "prettier": "^3.8.0",
        "supertest": "^7.0.0"
    }
}
