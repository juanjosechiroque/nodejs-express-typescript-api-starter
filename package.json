{
    "name": "nodejs-express-typescript-api-starter",
    "version": "1.0.0",
    "description": "TypeScript REST API starter with Express 5, MongoDB, JWT, Docker, CI/CD, and tests",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "start": "NODE_ENV=production node dist/index.js",
        "dev": "NODE_ENV=development nodemon index.ts",
        "build": "tsc",
        "validate": "eslint . && prettier --check .",
        "format": "prettier --write . && eslint . --fix",
        "prepare": "husky || true",
        "seed": "tsx src/scripts/seed.ts",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:all": "npm test && npm run test:integration",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --project tsconfig.check.json"
    },
    "keywords": [
        "express",
        "nodejs",
        "rest-api",
        "boilerplate",
        "mongodb",
        "jwt",
        "mongoose"
    ],
    "author": "juanjosechiroque",
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "express": "^5.0.1",
        "express-rate-limit": "^8.6.0",
        "helmet": "^8.3.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.8.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testcontainers/mongodb": "^12.0.4",
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.1.1",
        "@types/supertest": "^7.2.1",
        "@vitest/coverage-v8": "^4.1.10",
        "dotenv": "^17.4.2",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "nodemon": "^3.1.9",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.9.5",
        "supertest": "^7.2.2",
        "tsx": "^4.23.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.65.0",
        "vitest": "^4.1.10"
    },
    "allowScripts": {
        "bcrypt@6.0.0": true,
        "esbuild@0.28.1": true,
        "fsevents@2.3.3": true,
        "unrs-resolver@1.11.1": true
    }
}
