{
    "name": "nodejs-express-api-boilerplate",
    "version": "1.0.0",
    "description": "REST API boilerplate with Express 5, MongoDB, JWT, and tests",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "NODE_ENV=production node index.js",
        "dev": "NODE_ENV=development nodemon index.js",
        "validate": "eslint . && prettier --check .",
        "format": "prettier --write . && eslint . --fix",
        "prepare": "husky || true",
        "test": "NODE_OPTIONS=--experimental-vm-modules jest",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
    },
    "keywords": [
        "express",
        "nodejs",
        "rest-api",
        "boilerplate",
        "mongodb",
        "jwt",
        "mongoose"
    ],
    "author": "juanjosechiroque",
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "express": "^5.0.1",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.0.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.9.4",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "dotenv": "^16.4.7",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.0.0",
        "nodemon": "^3.1.9",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.1",
        "supertest": "^7.0.0"
    }
}
