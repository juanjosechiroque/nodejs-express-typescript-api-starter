#Environment
PORT=3000
NODE_ENV=development

#Database
MONGODB_URI=mongodb://localhost:27017/api_starter

#Docker Compose (optional)
# Overrides the MongoDB URI used by docker compose.
# Defaults to mongodb://mongo:27017/api_starter
COMPOSE_MONGODB_URI=

#Security
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION_TIME=1h
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

#Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_MAX=60

#Logging
LOG_LEVEL=info
